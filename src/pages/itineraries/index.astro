---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout
  title="Itineraries"
  description="Structured trips built from real experience — single-city guides, two-city pairings, and broader regional routes."
>
  <Header />

  <main>
    <section class="itin-hero">
      <div class="container">
        <p class="eyebrow">Globe &amp; Frame</p>
        <h1>Itineraries</h1>
        <p class="itin-hero__lead">
          Structured trips built from real experience — one city done well, two-city regional pairs, or a broader
          multi-destination route. Every itinerary is available on Etsy as an instant download.
        </p>
        <div class="itin-hero__tiers">
          <a class="itin-tier-link" href="/itineraries/3-day/">3 Days</a>
          <a class="itin-tier-link" href="/itineraries/7-day/">7 Days</a>
          <a class="itin-tier-link" href="/itineraries/10-day/">10 Days</a>
          <a class="itin-tier-link itin-tier-link--active" href="/custom-inquiry/">Custom Trip</a>
        </div>
      </div>
    </section>

    <div class="container">
      <div class="itin-tier-grid" style="margin-top:var(--space-xl);">
        <a class="itin-tier-card" href="/itineraries/3-day/">
          <span class="itin-tier-card__days">3</span>
          <span class="itin-tier-card__label">Days — Single City</span>
          <p class="itin-tier-card__desc">
            One city done well. Built for shorter stays, long weekends, and city breaks where structure matters most.
          </p>
          <span class="itin-tier-card__cta">Browse 3-day itineraries →</span>
        </a>
        <a class="itin-tier-card" href="/itineraries/7-day/">
          <span class="itin-tier-card__days">7</span>
          <span class="itin-tier-card__label">Days — Two Cities</span>
          <p class="itin-tier-card__desc">
            Regional pairings that feel coherent, not stitched together. Two cities connected by how they complement each
            other.
          </p>
          <span class="itin-tier-card__cta">Browse 7-day itineraries →</span>
        </a>
        <a class="itin-tier-card" href="/itineraries/10-day/">
          <span class="itin-tier-card__days">10</span>
          <span class="itin-tier-card__label">Days — Three Cities</span>
          <p class="itin-tier-card__desc">
            Broader regional routes with enough time to connect multiple destinations without turning the trip into a
            sprint.
          </p>
          <span class="itin-tier-card__cta">Browse 10-day itineraries →</span>
        </a>
      </div>
    </div>

    <section class="dreaming-cta">
      <div class="container dreaming-cta__inner">
        <div>
          <h3>Need something built for you?</h3>
          <p>
            Tell me where you want to go and I'll build a plan around the experience you're after — any destination, any
            length, any level of detail.
          </p>
        </div>
        <a class="button button--primary" href="/custom-inquiry/">Plan a Custom Trip</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
