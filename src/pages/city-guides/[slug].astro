---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { allCityGuides, publishedCityGuideSlugs, relatedGuides } from "../../data/city-guides";
import { articleSchema, itemListSchema } from "../../lib/seo";

export function getStaticPaths() {
  return allCityGuides
    .filter((guide) => publishedCityGuideSlugs.has(guide.slug) && guide.content)
    .map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const { guide } = Astro.props;
const content = guide.content!;
const hero = content.heroImage ?? `/images/city-guides/${guide.slug}.jpg`;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const related = relatedGuides(guide.slug);
const title = `${guide.name} Travel Guide`;
const description = guide.hook;
const jsonLd = [
  articleSchema({ title, description, url: pageUrl }),
  itemListSchema({
    name: `Things to do in ${guide.name}`,
    description,
    url: pageUrl,
    items: content.highlights.map((highlight) => ({ name: highlight.name })),
  }),
];
---

<BaseLayout {title} {description} image={hero} ogType="article" {jsonLd}>
  <Header />

  <main class="page">
    <div class="container">
      <p><a href="/city-guides/">&larr; City Guides</a></p>

      <article class="article-content">
        <p class="eyebrow">{guide.region}</p>
        <h1>{guide.name}</h1>
        <img src={hero} alt={guide.name} width="1200" height="800" loading="eager" decoding="async" />
        <p class="lead">{content.intro}</p>

        {content.bestTime && <p><strong>Best time to go:</strong> {content.bestTime}</p>}

        <h2>What to do</h2>
        <ul>
          {
            content.highlights.map((highlight) => (
              <li><strong>{highlight.name}.</strong> {highlight.note}</li>
            ))
          }
        </ul>

        {
          content.whereToEat && (
            <>
              <h2>Where to eat</h2>
              <ul>
                {content.whereToEat.map((item) => (
                  <li><strong>{item.name}.</strong> {item.note}</li>
                ))}
              </ul>
            </>
          )
        }

        {
          content.whereToStay && (
            <>
              <h2>Where to stay</h2>
              <ul>
                {content.whereToStay.map((item) => (
                  <li><strong>{item.name}.</strong> {item.note}</li>
                ))}
              </ul>
            </>
          )
        }

        {
          content.whatToSkip && (
            <>
              <h2>What to skip</h2>
              <ul>
                {content.whatToSkip.map((item) => <li>{item}</li>)}
              </ul>
            </>
          )
        }
      </article>

      <section class="section">
        <h2>Plan this trip</h2>
        <div style="display:flex;gap:var(--space-sm);flex-wrap:wrap;">
          {
            content.etsyItineraryUrl && (
              <a
                class="button button--primary"
                href={content.etsyItineraryUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Get the {guide.name} itinerary
              </a>
            )
          }
          <a class="button button--secondary" href="/custom-inquiry/">Plan a custom trip</a>
        </div>
      </section>

      {
        related.length > 0 && (
          <section class="section">
            <h2>Related guides</h2>
            <div class="card-grid">
              {related.map((item) => (
                <a class="card" href={`/city-guides/${item.slug}/`}>
                  <h3>{item.name}</h3>
                  <p>{item.hook}</p>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </main>

  <Footer />
</BaseLayout>
