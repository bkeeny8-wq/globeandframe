---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { cityGuideRegions } from "../data/city-guides";

const guideCount = new Set(cityGuideRegions.flatMap((region) => region.guides.map((guide) => guide.slug))).size;
const regionCount = cityGuideRegions.length;
---

<BaseLayout title="Globe & Frame">
  <Header />

  <main class="home">
    <!-- ─── HERO ─────────────────────────────────────── -->
    <section class="hero">
      <div class="container hero__inner">
        <div class="hero__body">
          <p class="eyebrow">Globe &amp; Frame</p>
          <h1>Plan better trips with guides built from real experience.</h1>
          <p class="hero__lead">
            Thoughtful itineraries, honest city breakdowns, and the places that define the experience. Start with a
            destination, or tell me where you want to go and I'll build the plan for you.
          </p>
          <div class="hero-ctas">
            <a class="button button--primary" href="/custom-inquiry/">Plan a Custom Trip</a>
            <a class="button button--ghost" href="/city-guides/">Browse City Guides</a>
            <a class="button button--ghost" href="/itineraries/">Ready-Made Itineraries</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── CUSTOM TRIP PITCH ────────────────────────── -->
    <section class="custom-pitch">
      <div class="container custom-pitch__inner">
        <div>
          <div class="custom-pitch__label">Custom Trip Planning</div>
          <h2>Tell me where you want to go.</h2>
          <p class="custom-pitch__body">
            I'll build a day-by-day plan around the experience you're actually looking for — where to eat, what to see,
            how to pace it, and what to skip. Built from 30+ countries of real experience, not a template.
          </p>
          <div class="custom-pitch__details">
            <div class="custom-pitch__detail">
              <span class="custom-pitch__detail-label">Built for</span>
              <span class="custom-pitch__detail-value">Any destination</span>
            </div>
            <div class="custom-pitch__detail">
              <span class="custom-pitch__detail-label">Trip length</span>
              <span class="custom-pitch__detail-value">3, 7, or 10 days</span>
            </div>
            <div class="custom-pitch__detail">
              <span class="custom-pitch__detail-label">Based on</span>
              <span class="custom-pitch__detail-value">Real experience</span>
            </div>
            <div class="custom-pitch__detail">
              <span class="custom-pitch__detail-label">Includes</span>
              <span class="custom-pitch__detail-value">Restaurants, sights, pacing</span>
            </div>
          </div>
        </div>
        <div class="custom-pitch__cta">
          <a class="button button--primary" href="/custom-inquiry/">Get Started</a>
        </div>
      </div>
    </section>

    <!-- ─── EXPLORE CARDS ───────────────────────────── -->
    <section class="explore">
      <div class="container">
        <h2 class="section__title">Explore Globe &amp; Frame</h2>
        <div class="explore-grid">
          <article class="explore-card explore-card--featured">
            <h3><a href="/custom-inquiry/">Custom Trip Planning</a></h3>
            <p>
              Tell me your destination, travel style, and how long you have. I'll build a day-by-day plan around the
              experience you're looking for — restaurants, sights, pacing, and what to skip.
            </p>
          </article>
          <article class="explore-card">
            <h3><a href="/city-guides/">Explore Destinations</a></h3>
            <p>
              Start with city guides shaped by the places, people, and experiences that stay with you. {guideCount}
              destinations across {regionCount} regions.
            </p>
          </article>
          <article class="explore-card">
            <h3><a href="/itineraries/">Ready-Made Itineraries</a></h3>
            <p>
              Use ready-made itineraries to bring your trip together with more clarity, confidence, and room to enjoy it.
            </p>
          </article>
          <article class="explore-card">
            <h3><a href="/elevate-your-travel/">Elevate Your Travel</a></h3>
            <p>
              Jet lag strategy, business class decisions, packing systems, and how to plan a trip that actually works.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ─── WHY GLOBE & FRAME ───────────────────────── -->
    <section class="why">
      <div class="container">
        <h2 class="section__title">Why Globe &amp; Frame</h2>
        <p class="section__intro">
          Most travel content tells you what exists. We tell you what's worth experiencing. Every guide is built from real
          experience — structured so you can actually use it.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
