---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Plan better trips with guides built from real experience." } = Astro.props;
const fullTitle = title === "Globe & Frame" ? title : `${title} — Globe & Frame`;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
